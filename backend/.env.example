# TrueScan Backend Environment Configuration v3
# Copy this to .env and fill in your values

# ── Core ─────────────────────────────────────────────────────────────────────
# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ── Authentication (Step F) ───────────────────────────────────────────────────
# Generate a strong random secret:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32

# JWT token lifetime in minutes (default 1440 = 24h)
JWT_EXPIRE_MINUTES=1440

# ── Fact-Check APIs (Step K) ──────────────────────────────────────────────────
# Google Fact Check Tools API (free, needs key):
#   https://developers.google.com/fact-check/tools/api/reference/rest
# Leave empty to use heuristic-only fallback.
GOOGLE_FACTCHECK_API_KEY=

# ClaimBuster API (free, needs key):
#   https://idir.uta.edu/claimbuster/
# Leave empty to skip.
CLAIMBUSTER_API_KEY=

# ── External AI APIs (New in v3.1) ───────────────────────────────────────────
# Google Gemini API (Free tier: 15 RPM)
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=

# Hugging Face Inference API (Free)
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Serper.dev API (Google Search - 2500 free credits)
# Get key at: https://serper.dev/
SERPER_API_KEY=

# Groq API (Ultra-fast LLM - Free)
# Get key at: https://console.groq.com/
GROQ_API_KEY=

# ── Model cache (optional) ────────────────────────────────────────────────────
# HuggingFace model cache directory
# HF_HOME=./hf_cache
